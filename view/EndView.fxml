<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>

<BorderPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="fr.uge.but.schtroumpf.controller.EndController"
            styleClass="root"
            prefWidth="900" prefHeight="620">
    <center>
        <VBox alignment="CENTER" spacing="18" style="-fx-padding: 36;">

            <VBox fx:id="bannerBox" styleClass="victory-banner"
                  alignment="CENTER" spacing="6">
                <Label fx:id="lblResultat" text="Victoire !"
                       style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #9FE1CB;"/>
                <Label fx:id="lblResultatSub" text="Le village a survécu 12 mois !"
                       style="-fx-font-size: 13; -fx-text-fill: #5DCAA5;"/>
            </VBox>

            <Label text="Ressources finales"
                   style="-fx-text-fill: #B5A68E; -fx-font-size: 11;"/>

            <HBox spacing="8" alignment="CENTER">
                <VBox styleClass="score-card" spacing="2">
                    <Label text="Baies" style="-fx-text-fill: #B5A68E; -fx-font-size: 9;"/>
                    <Label fx:id="lblBaies" text="0"
                           style="-fx-text-fill: #D85A30; -fx-font-size: 20; -fx-font-weight: bold;"/>
                </VBox>
                <VBox styleClass="score-card" spacing="2">
                    <Label text="Salsepar." style="-fx-text-fill: #B5A68E; -fx-font-size: 9;"/>
                    <Label fx:id="lblSalse" text="0"
                           style="-fx-text-fill: #1D9E75; -fx-font-size: 20; -fx-font-weight: bold;"/>
                </VBox>
                <VBox styleClass="score-card" spacing="2">
                    <Label text="Or" style="-fx-text-fill: #B5A68E; -fx-font-size: 9;"/>
                    <Label fx:id="lblOr" text="0"
                           style="-fx-text-fill: #BA7517; -fx-font-size: 20; -fx-font-weight: bold;"/>
                </VBox>
                <VBox styleClass="score-card" spacing="2">
                    <Label text="Outils" style="-fx-text-fill: #B5A68E; -fx-font-size: 9;"/>
                    <Label fx:id="lblOutils" text="0"
                           style="-fx-text-fill: #888780; -fx-font-size: 20; -fx-font-weight: bold;"/>
                </VBox>
                <VBox styleClass="score-card" spacing="2">
                    <Label text="Moral" style="-fx-text-fill: #B5A68E; -fx-font-size: 9;"/>
                    <Label fx:id="lblMoral" text="0"
                           style="-fx-text-fill: #7F77DD; -fx-font-size: 20; -fx-font-weight: bold;"/>
                </VBox>
                <VBox styleClass="score-card" spacing="2">
                    <Label text="Défense" style="-fx-text-fill: #B5A68E; -fx-font-size: 9;"/>
                    <Label fx:id="lblDefense" text="0"
                           style="-fx-text-fill: #378ADD; -fx-font-size: 20; -fx-font-weight: bold;"/>
                </VBox>
                <VBox styleClass="score-card" spacing="2">
                    <Label text="Savoir" style="-fx-text-fill: #B5A68E; -fx-font-size: 9;"/>
                    <Label fx:id="lblSavoir" text="0"
                           style="-fx-text-fill: #7F77DD; -fx-font-size: 20; -fx-font-weight: bold;"/>
                </VBox>
            </HBox>

            <VBox styleClass="score-total" spacing="4">
                <Label text="RANG" style="-fx-background-color: #2C2217;
                       -fx-text-fill: #BA7517; -fx-font-size: 10; -fx-font-weight: bold;
                       -fx-padding: 2 12; -fx-background-radius: 10;"/>
                <Label fx:id="lblScore" text="0 / 700"
                       style="-fx-text-fill: #FAEEDA; -fx-font-size: 28; -fx-font-weight: bold;"/>
                <Label fx:id="lblCommentaire" text=""
                       style="-fx-text-fill: #D4B896; -fx-font-size: 12;"/>
            </VBox>

            <HBox spacing="12" alignment="CENTER">
                <Button text="Rejouer" onAction="#handleRejouer" styleClass="btn-accent"/>
                <Button text="Quitter" onAction="#handleQuitter" styleClass="btn-secondary"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
